---
interface Props {
  title: string;
  slug: string;
  previewPath?: string;
}

const { title, slug, previewPath } = Astro.props;
---

<article class="exhibit-card">
  <a class="exhibit-card__link" href={`/exponate/${slug}/`}>
    <div class="exhibit-card__media" aria-hidden="true">
      {previewPath ? <img src={previewPath} alt="" loading="lazy" /> : <span class="exhibit-card__placeholder">{title}</span>}
    </div>
    <div class="exhibit-card__body">
      <h2>{title}</h2>
    </div>
  </a>
</article>
